# 数据库配置
DB_HOST=localhost
DB_USER=duijie
DB_PASSWORD=your_secure_password_here
DB_NAME=duijie_db

# 数据库 SSL（数据库远程连接时建议启用）
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT 密钥（请使用 node -e "console.log(require('crypto').randomBytes(64).toString('hex'))" 生成）
JWT_SECRET=replace_with_strong_random_secret

# 服务端口
PORT=1800

# 日志级别
LOG_LEVEL=info

# LLM AI 功能（可选）
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
